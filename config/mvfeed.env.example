# Runtime paths
MVFEED_HOME=/opt/mvfeed
MVFEED_DB_PATH=/opt/mvfeed/data/feed.db
MVFEED_PUBLIC_ROOT=/srv/mvfeed/public
MVFEED_STAGING_ROOT=/opt/mvfeed/staging
MVFEED_BACKUP_ROOT=/opt/mvfeed/backups
MVFEED_ROUTE_CONFIG=/etc/mvfeed/routes.json

# Collector tuning
MVFEED_WORKERS=16
MVFEED_BATCH_DELAY=0.20
MVFEED_REQUEST_DELAY=0.20
MVFEED_MAX_RETRIES=7
MVFEED_OVERLAP_HOURS=24
MVFEED_BACKUP_KEEP=7
MVFEED_USER_AGENT=KDC-USOM-MultiVendorFeed/1.0

# Optional source override
MVFEED_API_URL=https://siberguvenlik.gov.tr/api/address/index
